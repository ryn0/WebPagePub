{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch (http)",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/WebPagePub.WebApp/bin/Debug/net10.0/WebPagePub.WebApp.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/WebPagePub.WebApp",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7173;http://localhost:5283"
      }
    }
  ]
}
