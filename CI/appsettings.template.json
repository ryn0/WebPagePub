{
  "ConnectionStrings": {
    "PostgresConnection": "${POSTGRES_CONNECTION}"
  },
  "AmazonEmailCredentials": {
    "AccessKey": "${AWS_ACCESS_KEY}",
    "SecretKey": "${AWS_SECRET_KEY}",
    "EmailFrom": "${AWS_EMAIL_FROM}"
  },
  "IPinfo": {
    "AccessToken": "${IPINFO_ACCESS_TOKEN}"
  },
  "Logging": {
    "IncludeScopes": false,
    "LogLevel": {
      "Default": "Warning"
    }
  }
}
