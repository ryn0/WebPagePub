@model WebPagePub.WebApp.Models.SitePage.SitePageCommentListModel


@{
    ViewData["Title"] = "Comments";
}
<h2>@ViewData["Title"]</h2>
<hr />

 

<a href="~/commentmanagement/deletespam"
   onclick="return confirm('Are you sure you want to delete all posts marked as spam?')">Delete spam</a>

@if (Model != null && Model.Items.Count() > 0)
{


    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Comment</th>
                <th>Create Date</th>
                <th>Status</th>
                <th></th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @item.Name
                        @if (!string.IsNullOrWhiteSpace(item.Website))
                        {
                            <br /><small class="text-muted">@item.Website</small>
                        }
                    </td>
                    <td style="max-width:520px;">
                        @{
                            var preview = item.Comment ?? string.Empty;
                            if (preview.Length > 220) { preview = preview.Substring(0, 220) + "…"; }
                        }
                        @preview
                    </td>
                    <td>
                        @item.CreateDate
                    </td>
                    <td>
                        @item.CommentStatus
                    </td>
                    <td style="white-space:nowrap;">
                        <a href="~/commentmanagement/edit?SitePageCommentId=@item.SitePageCommentId">Edit</a>
                        <form asp-controller="CommentManagement" asp-action="Delete" method="post"
                              style="display:inline;margin-left:.5rem;"
                              onsubmit="return confirm('Delete this comment permanently?');">
                            <input type="hidden" name="sitePageCommentId" value="@item.SitePageCommentId" />
                            <input type="hidden" name="pageNumber" value="@Model.CurrentPageNumber" />
                            <button type="submit" class="btn btn-sm btn-danger" style="padding:.1rem .5rem;">Delete</button>
                        </form>
                    </td>

                </tr>
            }
        </tbody>
    </table>
}
else
{
    <br />
    <i>No comments</i>
}


@{
    int pageCount = Model?.PageCount ?? 0;

    for (int pageNumber = 1; pageNumber <= pageCount; pageNumber++)
    {
        if (Model?.CurrentPageNumber == pageNumber)
        {
            @pageNumber
        }
        else
        {
            <a href="@Url.Content("~/CommentManagement?&pageNumber=" + pageNumber.ToString())">@pageNumber.ToString()</a>
        }
    }

}