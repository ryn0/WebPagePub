@using WebPagePub.Services.Models.Sponsors
@model IReadOnlyList<SponsorCardItem>

@if (Model != null && Model.Count > 0)
{
    <section class="main-sponsors main-sponsors-sidebar" aria-label="Main sponsors">
        <h2 class="main-sponsors-heading">Main Sponsors</h2>
        <div class="sponsor-grid sponsor-grid-stacked">
            @foreach (var s in Model)
            {
                <div class="sponsor-card">
                    <div class="sponsor-card-header">
                        <a class="sponsor-card-name"
                           href="@s.Link"
                           target="_blank"
                           rel="noopener sponsored">@s.Name</a>
                        @if (s.ReviewCount > 0)
                        {
                            var pct = (Math.Max(0, Math.Min(5, s.ReviewRating)) / 5d * 100d).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                            <span class="sponsor-card-rating">
                                <a href="@s.ReviewLink" rel="nofollow"
                                   aria-label="@s.ReviewRating.ToString("0.0") out of 5 stars, @s.ReviewCount reviews">
                                    <span class="stars-wrap" aria-hidden="true">
                                        <span class="stars-empty">★★★★★</span>
                                        <span class="stars-fill" style="width:@(pct)%">★★★★★</span>
                                    </span>
                                    <span class="sponsor-card-rating-num">@s.ReviewRating.ToString("0.0")</span>
                                    <span class="sponsor-card-rating-count">(@s.ReviewCount)</span>
                                </a>
                            </span>
                        }
                    </div>
                    <p class="sponsor-card-description">@s.Description</p>
                    @if (!string.IsNullOrWhiteSpace(s.Note))
                    {
                        <p class="sponsor-card-note">@s.Note</p>
                    }
                </div>
            }
        </div>
    </section>
}